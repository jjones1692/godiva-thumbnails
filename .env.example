# Copy this file to .env and paste your real keys after the = sign. Never commit .env.

# Nano Banana 2 (Gemini) — required for rendering. https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# Envato API personal token — OPTIONAL. https://build.envato.com
# NOTE: this token talks to the Envato MARKET API (search + item metadata). It does NOT
# download licensed Envato ELEMENTS files; Elements downloads go through the connected
# Envato MCP into assets/envato/. Use this token only for Market catalog search/lookup.
ENVATO_API_TOKEN=your_token_here
